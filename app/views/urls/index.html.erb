<% content_for :title, "Shorty — url Shortener" %>

<div class="hero">
  <h1 class="hero-title">Paste the URL to be shortened</h1>

  <div class="form-card">
    <%= form_with model: @url, url: urls_path do |f| %>
      <% if @url.errors.any? %>
        <div class="form-errors">
          <% @url.errors.full_messages.each do |msg| %><p><%= msg %></p><% end %>
        </div>
      <% end %>

      <div class="form-row-primary">
        <%= f.url_field :original_url,
              placeholder: "Enter the link here",
              class: "form-input",
              required: true,
              autofocus: true %>
        <%= f.submit "Shorten URL", class: "btn-shorten" %>
      </div>

      <%# Custom alias — logged-in only %>
      <% if user_signed_in? %>
        <button type="button" class="alias-toggle" id="alias-toggle">+ customize alias</button>
        <div class="alias-row" id="alias-row" hidden>
          <%= f.text_field :short_code,
                placeholder: "my-alias",
                class: "form-input-alias",
                pattern: "[A-Za-z0-9_-]{3,20}",
                title: "3–20 characters, letters/numbers/- only" %>
        </div>
      <% end %>
    <% end %>
  </div>

  <p class="hero-hint">Free URL shortener. Shorten links and track clicks.</p>
</div>

<div class="tools-card">
  <div class="tools-tabs">
    <button class="tools-tab active" data-tab="lengthen">Lengthen</button>
    <button class="tools-tab" data-tab="expand">Expand</button>
  </div>

  <%# Lengthen panel %>
  <div id="tab-lengthen" class="tools-panel">
    <p class="expand-hint">Paste any link and we'll make it absurdly, ridiculously, unnecessarily long.</p>
    <div class="expand-row">
      <input type="url" id="lengthen-input" class="form-input" placeholder="https://example.com" />
      <button id="lengthen-btn" class="btn-shorten">Lengthen</button>
    </div>
    <div id="lengthen-result" hidden>
      <span class="expand-result-label">Long URL:</span>
      <a id="lengthen-result-url" href="#" target="_blank" rel="noopener noreferrer" class="expand-result-link"></a>
      <button class="copy-btn" id="lengthen-copy-btn">Copy</button>
    </div>
    <p id="lengthen-error" class="form-errors" hidden></p>
  </div>

  <%# Expand panel %>
  <div id="tab-expand" class="tools-panel" hidden>
    <p class="expand-hint">Paste any short link to reveal the final destination before clicking it.</p>
    <div class="expand-row">
      <input type="url" id="expand-input" class="form-input" placeholder="https://bit.ly/..." />
      <button id="expand-btn" class="btn-shorten">Expand</button>
    </div>
    <div id="expand-result" hidden>
      <span class="expand-result-label">Final URL:</span>
      <a id="expand-result-url" href="#" target="_blank" rel="noopener noreferrer" class="expand-result-link"></a>
      <button class="copy-btn" id="expand-copy-btn">Copy</button>
    </div>
    <p id="expand-error" class="form-errors" hidden></p>
  </div>
</div>

<%# Guest result — shows after shortening without an account %>
<% if flash[:guest_short_url].present? %>
  <div class="guest-result">
    <p class="guest-result-label">Your short link is ready</p>
    <div class="guest-result-row">
      <%= link_to flash[:guest_short_url], flash[:guest_short_url],
            target: "_blank", rel: "noopener noreferrer",
            class: "guest-result-url" %>
      <button class="copy-btn copy-btn-lg" data-url="<%= flash[:guest_short_url] %>">Copy</button>
    </div>
    <p class="guest-result-hint">
      <%= link_to "Sign up free", new_user_registration_path %> to save links, track analytics, and create custom aliases.
    </p>
  </div>
<% end %>

<%# Dashboard — signed-in users only %>
<% if @urls.any? %>
  <section class="links-section">
    <div class="links-header">
      <h2 class="links-title">Your links</h2>
      <span class="links-count" id="links-count"><%= @urls.size %></span>
      <div class="links-filter">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="short">Short</button>
        <button class="filter-btn" data-filter="long">Long</button>
      </div>
    </div>

    <%= turbo_stream_from "urls_#{current_user.id}" %>
    <div class="links-list" id="urls_list">
      <% @urls.each do |url| %>
        <%= render "url", url: url %>
      <% end %>
    </div>
  </section>

<% elsif user_signed_in? %>
  <%= turbo_stream_from "urls_#{current_user.id}" %>
  <div class="links-list" id="urls_list"></div>
  <div class="empty-state">
    <p>No links yet — paste a URL above to get started.</p>
  </div>

<% elsif flash[:guest_short_url].blank? %>
  <%# Only show CTA if guest hasn't just created a link %>
  <div class="cta-section">
    <p>Create a free account to save links, track analytics, and use custom aliases.</p>
    <%= link_to "Create free account", new_user_registration_path, class: "btn btn-primary" %>
    <%= link_to "Sign in", new_user_session_path, class: "btn btn-outline" %>
  </div>
<% end %>

<script type="module">
  const urlInput = document.querySelector('.form-input');
  const shortenBtn = document.querySelector('.btn-shorten');
  const form = document.querySelector('form');

  // Fitts's Law: '/' keyboard shortcut = no hunting for input
  document.addEventListener('keydown', e => {
    const tag = document.activeElement?.tagName;
    if (e.key === '/' && tag !== 'INPUT' && tag !== 'TEXTAREA') {
      e.preventDefault();
      urlInput?.focus();
      urlInput?.select();
    }
  });

  // Doherty Threshold: instant feedback on submit (<400ms perceived)
  form?.addEventListener('submit', () => {
    if (shortenBtn && !shortenBtn.disabled) {
      shortenBtn.textContent = 'Shortening...';
      shortenBtn.disabled = true;
      shortenBtn.style.opacity = '0.7';
    }
  });

  // Alias toggle
  const toggle = document.getElementById('alias-toggle');
  const row    = document.getElementById('alias-row');
  if (toggle && row) {
    toggle.addEventListener('click', () => {
      const hidden = row.hasAttribute('hidden');
      row.toggleAttribute('hidden', !hidden);
      toggle.textContent = hidden ? '− hide alias' : '+ customize alias';
      if (hidden) row.querySelector('input')?.focus();
    });
    if (row.querySelector('input')?.value) {
      row.removeAttribute('hidden');
      toggle.textContent = '− hide alias';
    }
  }

  // Copy: event delegation so Turbo stream-added cards also work
  function copyToClipboard(text) {
    if (navigator.clipboard && window.isSecureContext) {
      return navigator.clipboard.writeText(text);
    }
    // Fallback for HTTP / non-secure contexts
    const ta = document.createElement('textarea');
    ta.value = text;
    ta.style.cssText = 'position:fixed;top:0;left:0;opacity:0;pointer-events:none';
    document.body.appendChild(ta);
    ta.focus();
    ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
    return Promise.resolve();
  }

  document.addEventListener('click', e => {
    const btn = e.target.closest('.copy-btn');
    if (!btn) return;
    const url = btn.dataset.url;
    if (!url) return;
    copyToClipboard(url).then(() => {
      const orig = btn.textContent;
      btn.textContent = '✓ Copied';
      btn.classList.add('copied');
      setTimeout(() => { btn.textContent = orig; btn.classList.remove('copied'); }, 1800);
    });
  });

  // Hint: show keyboard shortcut hint in placeholder
  if (urlInput && !urlInput.value) {
    setTimeout(() => {
      if (!urlInput.matches(':focus'))
        urlInput.placeholder = 'Enter the link here  \u00b7  press / to focus';
    }, 1500);
    urlInput.addEventListener('focus', () => {
      urlInput.placeholder = 'https://paste-your-long-url-here.com';
    });
  }

  // ── Real-time click counts — poll every 15s, update only changed numbers ──
  function pollClicks() {
    if (!document.querySelector('[data-url-id]')) return;
    fetch('/urls/click_counts', { headers: { Accept: 'application/json' } })
      .then(r => r.ok ? r.json() : [])
      .then(data => {
        data.forEach(({ id, clicks }) => {
          const card = document.querySelector(`[data-url-id="${id}"]`);
          const el = card?.querySelector('.link-clicks');
          if (!el) return;
          const label = `${clicks} ${clicks === 1 ? 'click' : 'clicks'}`;
          if (el.textContent.trim() !== label) {
            el.textContent = label;
            // Flash animation so user notices the update
            el.classList.remove('count-updated');
            void el.offsetWidth; // reflow to restart
            el.classList.add('count-updated');
            setTimeout(() => el.classList.remove('count-updated'), 500);
          }
        });
      })
      .catch(() => {}); // silent fail — user just won't see update if offline
  }

  // Start polling only if there are links on screen
  if (document.querySelector('[data-url-id]')) {
    setInterval(pollClicks, 10_000);
  }

  // ── Filter tabs ──────────────────────────────────────────────────────
  const filterBtns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.link-card[data-kind]');
  const countEl = document.getElementById('links-count');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = btn.dataset.filter;
      let visible = 0;
      cards.forEach(card => {
        const show = filter === 'all' || card.dataset.kind === filter;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (countEl) countEl.textContent = visible;
    });
  });

  // ── Tools tabs (Lengthen / Expand) ───────────────────────────────────
  document.querySelectorAll('.tools-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.tools-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.tools-panel').forEach(p => p.hidden = true);
      tab.classList.add('active');
      document.getElementById('tab-' + tab.dataset.tab).hidden = false;
    });
  });
</script>

<script type="module">
  const input   = document.getElementById('expand-input');
  const btn     = document.getElementById('expand-btn');
  const result  = document.getElementById('expand-result');
  const resultUrl = document.getElementById('expand-result-url');
  const copyBtn = document.getElementById('expand-copy-btn');
  const errEl   = document.getElementById('expand-error');

  btn.addEventListener('click', async () => {
    const url = input.value.trim();
    if (!url) return;

    btn.disabled = true;
    btn.textContent = 'Expanding…';
    result.hidden = true;
    errEl.hidden = true;

    try {
      const resp = await fetch('<%= expand_urls_path %>', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content
        },
        body: JSON.stringify({ url })
      });
      const data = await resp.json();
      if (data.error) throw new Error(data.error);

      resultUrl.href = data.expanded;
      resultUrl.textContent = data.expanded;
      copyBtn.dataset.url = data.expanded;
      result.hidden = false;
    } catch (e) {
      errEl.textContent = e.message;
      errEl.hidden = false;
    } finally {
      btn.disabled = false;
      btn.textContent = 'Expand';
    }
  });

  input.addEventListener('keydown', e => { if (e.key === 'Enter') btn.click(); });
</script>

<script type="module">
  const input   = document.getElementById('lengthen-input');
  const btn     = document.getElementById('lengthen-btn');
  const result  = document.getElementById('lengthen-result');
  const resultUrl = document.getElementById('lengthen-result-url');
  const copyBtn = document.getElementById('lengthen-copy-btn');
  const errEl   = document.getElementById('lengthen-error');

  btn.addEventListener('click', async () => {
    const url = input.value.trim();
    if (!url) return;

    btn.disabled = true;
    btn.textContent = 'Lengthening…';
    result.hidden = true;
    errEl.hidden = true;

    try {
      const resp = await fetch('<%= lengthen_urls_path %>', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content
        },
        body: JSON.stringify({ url })
      });
      const data = await resp.json();
      if (data.error) throw new Error(data.error);
      window.location.reload();
    } catch (e) {
      errEl.textContent = e.message;
      errEl.hidden = false;
    } finally {
      btn.disabled = false;
      btn.textContent = 'Lengthen';
    }
  });

  input.addEventListener('keydown', e => { if (e.key === 'Enter') btn.click(); });
</script>
