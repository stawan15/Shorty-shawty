<% content_for :title, "Analytics — #{@url.short_code}" %>

<div class="page-header">
  <div>
    <h1 class="page-title">Analytics</h1>
    <p class="page-sub">
      <%= link_to short_url_for(@url), redirect_short_url_path(@url.short_code),
            target: "_blank", rel: "noopener noreferrer", class: "link-short" %>
      &rarr;
      <%= link_to truncate(@url.original_url, length: 60), @url.original_url,
            target: "_blank", rel: "noopener noreferrer", class: "link-muted" %>
    </p>
  </div>
  <%= link_to "← Back", root_path, class: "btn btn-outline" %>
</div>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-value"><%= @url.clicks %></div>
    <div class="stat-label">Total Clicks</div>
  </div>
  <div class="stat-card">
    <div class="stat-value"><%= @clicks_by_day.size %></div>
    <div class="stat-label">Active Days</div>
  </div>
  <div class="stat-card">
    <div class="stat-value"><%= @url.created_at.strftime("%b %d") %></div>
    <div class="stat-label">Created</div>
  </div>
  <div class="stat-card">
    <div class="qr-preview">
      <%= image_tag qr_code_url_path(@url), alt: "QR Code", class: "qr-img" %>
    </div>
    <div class="stat-label">QR Code <a href="<%= qr_code_url_path(@url) %>" download="qr-<%= @url.short_code %>.svg" class="link-muted">(download)</a></div>
  </div>
</div>

<div class="analytics-grid">
  <section class="card">
    <h2 class="card-title">Clicks by Day</h2>
    <% if @clicks_by_day.any? %>
      <table class="url-table">
        <thead>
          <tr>
            <th>Date</th>
            <th class="text-right">Clicks</th>
            <th>Bar</th>
          </tr>
        </thead>
        <tbody>
          <% max = @clicks_by_day.values.max.to_f %>
          <% @clicks_by_day.each do |date, count| %>
            <tr>
              <td><%= date %></td>
              <td class="text-right"><strong><%= count %></strong></td>
              <td>
                <div class="bar-track">
                  <div class="bar-fill" style="width: <%= (count / max * 100).round %>%"></div>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="empty-msg">No clicks recorded yet.</p>
    <% end %>
  </section>

  <section class="card">
    <h2 class="card-title">Recent Clicks</h2>
    <% if @recent_clicks.any? %>
      <table class="url-table">
        <thead>
          <tr>
            <th>Time</th>
            <th>Referrer</th>
            <th>Location</th>
          </tr>
        </thead>
        <tbody>
          <% @recent_clicks.each do |click| %>
            <tr>
              <td class="td-date"><%= click.created_at.strftime("%b %d %H:%M") %></td>
              <td class="td-original">
                <% if click.referrer.present? %>
                  <%= truncate(click.referrer, length: 40) %>
                <% else %>
                  <span class="muted">Direct</span>
                <% end %>
              </td>
              <td class="td-original muted"><%= click.ip_address %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="empty-msg">No click details recorded yet.</p>
    <% end %>
  </section>
</div>
