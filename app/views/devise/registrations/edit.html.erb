<div class="devise-form" style="margin:2rem auto; max-width:480px">

  <div style="margin-bottom:1.75rem">
    <%= link_to "← Back", root_path, class: "qr-back" %>
  </div>

  <h2>Account Settings</h2>
  <p class="devise-form-subtitle">Update your email or password.</p>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="field">
      <%= f.label :email %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <span class="field-hint">Awaiting confirmation for: <strong><%= resource.unconfirmed_email %></strong></span>
      <% end %>
    </div>

    <div class="field">
      <%= f.label :password, "New Password" %>
      <span class="field-hint">Leave blank to keep your current password</span>
      <%= f.password_field :password, autocomplete: "new-password", placeholder: "New password" %>
      <% if @minimum_password_length %>
        <span class="field-hint"><%= @minimum_password_length %> characters minimum</span>
      <% end %>
    </div>

    <div class="field">
      <%= f.label :password_confirmation, "Confirm New Password" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "Confirm new password" %>
    </div>

    <div class="field">
      <%= f.label :current_password, "Current Password" %>
      <span class="field-hint">Required to save any changes</span>
      <%= f.password_field :current_password, autocomplete: "current-password", placeholder: "Your current password" %>
    </div>

    <div class="actions">
      <%= f.submit "Save changes" %>
    </div>
  <% end %>

  <hr class="danger-zone-divider">

  <p class="danger-zone-title">Danger Zone</p>
  <%= button_to "Delete my account", registration_path(resource_name),
        data: { turbo_confirm: "This will permanently delete your account and all your URLs. Are you sure?" },
        method: :delete,
        class: "btn btn-outline",
        style: "color:var(--red);border-color:rgba(220,38,38,.3);width:100%;justify-content:center" %>

</div>
