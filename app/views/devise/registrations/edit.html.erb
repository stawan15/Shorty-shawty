<div class="devise-form" style="margin:2rem auto; max-width:480px">
  <%= link_to root_path, class: "devise-form-brand" do %>
    <span class="devise-form-brand-dot"></span>shorty
  <% end %>

  <h2>Account Settings</h2>
  <p class="devise-form-subtitle">Manage your email, password, and API access.</p>

  <% if current_user.api_token.present? %>
    <div class="token-box">
      <p class="token-box-label">API Token</p>
      <code><%= current_user.api_token %></code>
      <p class="token-box-hint">Use as: <code>Authorization: Bearer &lt;token&gt;</code></p>
    </div>
  <% end %>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="field">
      <%= f.label :email %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <p class="field-hint">Awaiting confirmation for: <strong><%= resource.unconfirmed_email %></strong></p>
      <% end %>
    </div>

    <div class="field">
      <%= f.label :password, "New Password" %>
      <p class="field-hint">Leave blank to keep your current password</p>
      <%= f.password_field :password, autocomplete: "new-password", placeholder: "New password" %>
      <% if @minimum_password_length %>
        <p class="field-hint"><%= @minimum_password_length %> characters minimum</p>
      <% end %>
    </div>

    <div class="field">
      <%= f.label :password_confirmation, "Confirm New Password" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "Confirm new password" %>
    </div>

    <div class="field">
      <%= f.label :current_password, "Current Password" %>
      <p class="field-hint">Required to save any changes</p>
      <%= f.password_field :current_password, autocomplete: "current-password", placeholder: "Your current password" %>
    </div>

    <div class="actions">
      <%= f.submit "Save changes" %>
    </div>
  <% end %>

  <hr class="danger-zone-divider">

  <p class="danger-zone-title">Danger Zone</p>
  <%= button_to "Delete my account", registration_path(resource_name),
        data: { turbo_confirm: "This will permanently delete your account and all your URLs. Are you sure?" },
        method: :delete,
        class: "btn btn-outline",
        style: "color:var(--red-fg);border-color:rgba(185,28,28,.35);width:100%;justify-content:center" %>

  <div class="devise-links" style="margin-top:1rem">
    <%= link_to "Back to dashboard", root_path %>
  </div>
</div>
