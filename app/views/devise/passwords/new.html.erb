<div class="devise-form" style="margin:2rem auto">
  <%= link_to root_path, class: "devise-form-brand" do %>
    <span class="devise-form-brand-dot"></span>shorty
  <% end %>

  <h2>Reset password</h2>
  <p class="devise-form-subtitle">We'll email you a link to reset your password.</p>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="field">
      <%= f.label :email %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "you@example.com" %>
    </div>

    <div class="actions">
      <%= f.submit "Send reset instructions" %>
    </div>
  <% end %>

  <div class="devise-links">
    <%= render "devise/shared/links" %>
  </div>
</div>
