{
  "name": "shorty",
  "description": "URL Shortener built with Rails",
  "scripts": {
    "dokku": {
      "predeploy": "bundle exec rails db:migrate"
    }
  },
  "formation": {
    "web": {
      "quantity": 1
    }
  },
  "env": {
    "RAILS_ENV": {
      "value": "production"
    },
    "RAILS_LOG_TO_STDOUT": {
      "value": "enabled"
    },
    "RAILS_SERVE_STATIC_FILES": {
      "value": "true"
    },
    "WEB_CONCURRENCY": {
      "value": "2",
      "description": "Puma workers — enables phased (zero-downtime) restart on Dokku"
    }
  }
}
